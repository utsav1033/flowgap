# Copy to .env and fill in your key(s).
# Only GEMINI_API_KEY is required for the default setup (labeling + node drafting).
# OPENAI_API_KEY is only needed if you set EMBEDDING_PROVIDER=openai.

GEMINI_API_KEY=your_gemini_api_key_here

# Optional — defaults to "local" (MiniLM via sentence-transformers, no API needed)
EMBEDDING_PROVIDER=local

# Only required if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
